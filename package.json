{
  "name": "brainsync-party-games",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite --host 0.0.0.0",
    "data:idioms": "node scripts/generate-idiom-data.mjs",
    "build": "tsc --noEmit && npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "node scripts/build-server.mjs",
    "miniapp:install": "npm install --prefix apps/miniapp",
    "miniapp:dev:mp-weixin": "npm run dev:mp-weixin --prefix apps/miniapp",
    "miniapp:build:mp-weixin": "npm run build:mp-weixin --prefix apps/miniapp",
    "start": "node dist-server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run test && npm run build",
    "check:release": "npm run test && npm run build && npm run miniapp:build:mp-weixin"
  },
  "dependencies": {
    "express": "^4.21.2",
    "mysql2": "^3.22.4",
    "socket.io": "^4.8.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "chinese-idiom-chengyu": "^1.1.0",
    "concurrently": "^9.1.0",
    "esbuild": "^0.24.2",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io-client": "^4.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
