PORT=3000
ROUND_SECONDS=30
PVP_HINT_REMAINING_SECONDS=15

# 账号和PVE猜歌挑战需要MySQL。未配置时，PVP开房间仍可使用，账号/PVE API会明确返回不可用。
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=brainsync
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=brainsync

# 也可以用连接串替代上面的分项配置。
# MYSQL_CONNECTION_URI=mysql://brainsync:change-me@127.0.0.1:3306/brainsync

# 微信小程序登录。AppSecret只能配置在服务端环境变量里，不能写入小程序前端。
WECHAT_APP_ID=wx-your-app-id
WECHAT_APP_SECRET=change-me

# 广告奖励回调校验。未配置时，广告回调接口会明确返回不可用。
UNI_AD_CALLBACK_SECRET=change-me

# 小程序前端构建时配置，指向正式HTTPS/WSS域名。
VITE_API_BASE_URL=https://your-domain.example
VITE_WS_URL=wss://your-domain.example/pvp-ws
VITE_REWARD_AD_UNIT_ID=adunit-your-reward-id
